{
  "name": "agentic-space-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend do Agentic Space: visibilidade do ecossistema, perfil de usuario, perfil de agente e cadastro de agentes.",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "npm run clean && next build",
    "build:static": "npm run clean && next build && npm run create-redirects && npm run copy-to-backend",
    "start": "next start",
    "lint": "next lint",
    "build:install": "npm install",
    "clean": "rm -rf .next out",
    "create-redirects": "node scripts/create-redirects.js",
    "copy-to-backend": "bash scripts/copy-to-backend.sh"
  },
  "dependencies": {
    "@metamask/sdk": "^0.34.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@walletconnect/ethereum-provider": "^2.23.10",
    "did-jwt": "^7.4.4",
    "ethers": "^6.9.0",
    "gray-matter": "^4.0.3",
    "he": "^1.2.0",
    "lucide-react": "^0.456.0",
    "next": "^14.2.33",
    "next-intl": "^4.13.1",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15"
  },
  "engines": {
    "node": ">=18.x"
  }
}
